FROM pytorch/pytorch:2.1.0-cuda12.1-cudnn8-devel

RUN apt-get update && apt-get install -y git curl && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    transformers>=4.40 \
    accelerate>=0.28 \
    peft>=0.8 \
    bitsandbytes>=0.43 \
    trl>=0.8 \
    datasets>=2.0 \
    tensorboard>=2.15 \
    scikit-learn>=1.3 \
    nltk>=3.8 \
    rouge-score>=0.1 \
    pyyaml>=6.0 \
    pydantic>=2.0 \
    rich>=13.0

WORKDIR /workspace

ENTRYPOINT ["python"]
