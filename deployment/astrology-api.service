[Unit]
Description=Astrology LLM API Server
After=network.target docker.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/astrology-llm

# Start with Docker Compose
ExecStart=/usr/bin/docker compose -f /opt/astrology-llm/deployment/docker-compose.yml up --build
ExecStop=/usr/bin/docker compose -f /opt/astrology-llm/deployment/docker-compose.yml down
Restart=always
RestartSec=10

# Graceful shutdown
TimeoutStartSec=300
TimeoutStopSec=60

# Environment
Environment=ASTROLOGY_MODEL_PATH=Qwen/Qwen2.5-3B-Instruct
Environment=ASTROLOGY_USE_VLLM=1

[Install]
WantedBy=multi-user.target
